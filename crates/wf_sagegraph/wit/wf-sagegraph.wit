// wf_sagegraph WIT world — v0.2.0.
//
// GraphSAGE-family node embeddings as a substrate function. Three
// exports (`embed` / `sweep` / `search`) sitting on top of ONNX
// (via `onnxruntime-wasm` or `wonnx-wasm`), GraphBLAS (via
// `graphblas-wasm`), and LAPACK (via `lapack-wasm`). Text-attributed
// feature extraction rides `fastembed-wasm`. Host `execute-query`
// callback (memo §03) fetches the k-hop neighborhood on demand.
//
// Design memo: docs/design/wf-sagegraph.md in the wf-conformance repo.
//
// # v0.2 status — guest body landed, ONNX path stubbed.
//
// The WIT world declared here matches the memo §04 shape. The Rust
// guest under `src/lib.rs` implements the three exports end-to-end:
//
//   * `embed` — issues `host::execute-query` for the node's k-hop
//     neighborhood, extracts structural degree features, aggregates via
//     mean-pool over neighbor features, applies a deterministic
//     "linear projection + activation" placeholder standing in for the
//     ONNX forward pass. The placeholder is byte-stable per
//     `model_url` so downstream consumers get deterministic vectors;
//     swap in real `onnxruntime-wasm` / `wonnx-wasm` in v0.3 without a
//     WIT churn.
//   * `sweep` — iterates every subject via `host::execute-query`,
//     embeds each, writes rows to `target-sink-url` via
//     `host::http-post-json`. Returns the count of rows written.
//   * `search` — POSTs a JSON body to the substrate's vector-search
//     endpoint (derived from `model-url`'s registered wf-vector sink)
//     via `host::http-post-json`, parses the returned hits.
//
// # ONNX honesty note
//
// v0.2 does NOT actually load an ONNX file. Composing `wonnx` or
// `onnxruntime-wasm` into a cargo-component `cdylib` in one session
// hits real toolchain walls (component-model target, WebGPU backend,
// wasi-nn abi). The `model-url` is fed into a deterministic hash used
// to seed the placeholder projection so operators can swap between
// "models" and observe the vector change — the ABI is honest, the
// numerics are placeholders. v0.3 replaces the projection with real
// ONNX behind the same `embed` signature.

package wf:sagegraph@0.2.0;

interface types {
    /// Feature-extraction source for a node. Selected per registered
    /// model via `embed-opts.features` / `sweep-opts.features`.
    variant node-features {
        /// Degree / clustering coefficient / PageRank score computed
        /// over the k-hop subgraph via GraphBLAS. Cheap; the honest
        /// fallback when nodes carry no explicit features. (Memo §06)
        structural(structural-opts),
        /// SPARQL-extracted structured properties. The registry entry
        /// names a query template the guest issues via the host
        /// `execute-query` callback; results become the input feature
        /// vector.
        attribute(attribute-opts),
        /// Sentence-embedding of one or more literals (rdfs:label,
        /// rdfs:comment, skos:definition, …). Uses `fastembed-wasm`
        /// (default: all-MiniLM-L6-v2, 384-dim). Recommended default
        /// per memo §06.
        text-attributed(text-opts),
    }

    /// Structural feature descriptor. Empty in v0.1 — the guest
    /// computes the fixed [degree, clustering, PageRank] triple. v0.2
    /// admits per-model toggles.
    record structural-opts {
        // Placeholder — see comment above. Present as a record so the
        // WIT variant can be extended without a breaking change.
        placeholder: option<string>,
    }

    record attribute-opts {
        /// SPARQL template the guest issues via the host callback to
        /// extract per-node structured features. `{{node}}` is
        /// substituted for the target subject IRI at dispatch time.
        query-template: string,
        /// XSD-typed columns the query is expected to return.
        columns: list<attribute-column>,
    }

    record attribute-column {
        variable: string,
        xsd-type: string,
    }

    record text-opts {
        /// Predicates whose literal objects supply the text signal.
        /// Fetched via the host callback and passed to
        /// `fastembed-wasm` in registered order.
        predicates: list<string>,
        /// Sentence-embedding model URL. Defaults to
        /// `all-MiniLM-L6-v2` (384-dim) when absent.
        model-url: option<string>,
    }

    /// One returned KNN hit — mirror of `wf-vector`'s `hit`. Score
    /// contract is `xsd:double` on the wire so the `wf_pyreason_bridge`
    /// (memo §10) sees the same shape regardless of upstream primitive.
    record hit {
        node: string,
        score: f64,
    }

    record embed-opts {
        /// Output embedding dimension. The stubbed ONNX projection
        /// always emits a vector of length `dimensions`. When a real
        /// ONNX model lands in v0.3 the dimension will come from the
        /// model file's output-shape metadata and this field becomes a
        /// consistency check.
        dimensions: u32,
        /// Neighbor-aggregation pool. `"mean"` (default) | `"max"` |
        /// `"sum"`. Backed by a GraphBLAS semiring; see memo §07 for
        /// the mapping.
        pool: string,
        /// ONNX runtime — `"onnxruntime"` (default) | `"wonnx"`. Both
        /// consume the same ONNX file (memo §08).
        runtime: option<string>,
        /// Per-call fuel budget. Enforced by the substrate wasm
        /// envelope; a k-hop expansion that exceeds this is a hard
        /// error unless SERVICE SILENT.
        fuel-limit: option<u64>,
    }

    record sweep-opts {
        dimensions: u32,
        pool: string,
        /// Nodes-per-batch across the SPARQL sweep. Tuning knob;
        /// operator's problem to set for their corpus size.
        batch-size: u32,
        /// Concurrent inference jobs.
        concurrency: u32,
    }

    record search-opts {
        /// Distance metric. `"cosine"` (default) | `"l2"`. Mirrors
        /// `wf-vector`'s registry (memo §04).
        metric: option<string>,
        /// KNN oversample factor before re-ranking. Same knob as
        /// `wf-vector`'s (memo §09 there).
        oversample: option<u32>,
    }
}

/// Host callbacks. Provided by the plugin; consumed by the wasm
/// component. Package-scoped so the host-side registration
/// (`wf:sagegraph/host@0.2.0`) matches the guest-side import verbatim
/// and cargo-component's linker can hook them up.
interface host {
    /// Issue a SPARQL query against the surrounding substrate. Returns
    /// SPARQL Results JSON verbatim so the guest can parse with its
    /// own serde_json. Any network error, parse failure, or
    /// non-successful evaluation surfaces as `Err(<message>)`. This is
    /// the load-bearing v0.2 primitive: without it the guest cannot
    /// fetch its own k-hop neighborhood.
    execute-query: func(query: string) -> result<string, string>;

    /// POST a JSON `body` to `url` and return the response body as a
    /// string. Success = HTTP 2xx; non-2xx / transport / URL errors
    /// surface as `Err(<message>)`. Used for sweep-side sink writes
    /// and search-side vector-index lookups. Same shape wf_fulltext /
    /// wf_document already ship.
    http-post-json: func(url: string, body: string) -> result<string, string>;
}

world wf-sagegraph {
    use types.{
        node-features, embed-opts, sweep-opts, search-opts, hit,
        structural-opts, attribute-opts, attribute-column, text-opts,
    };

    import host;

    // ------------------------------------------------------------------
    // Exports — see memo §04.
    // ------------------------------------------------------------------

    /// On-the-fly inference. Guest fetches `node-iri`'s k-hop
    /// neighborhood via the host callback, aggregates via GraphBLAS,
    /// applies the ONNX model, returns a K-dim vector. Slow per query
    /// (bounded by neighborhood size × ONNX forward); fine for
    /// interactive "embed this one node" use, tier-2 (sweep +
    /// wf-vector cache) for scan-heavy queries.
    export embed: func(node-iri: string, model-url: string,
                       k-hops: u32, opts: embed-opts)
                       -> result<list<f32>, string>;

    /// Precompute path. Iterates every node matching
    /// `subject-pattern`, runs inference, writes each vector to the
    /// `wf-vector:` sink at `target-sink-url`. Returns the number of
    /// rows written.
    ///
    /// `subject-pattern` is a SPARQL `SELECT ?s WHERE { … }` fragment;
    /// the guest issues it verbatim through `host::execute-query`.
    /// `target-sink-url` is any URL the substrate's sink layer accepts
    /// (`postgres://`, `jsonl:///…`, or the substrate's vector-index
    /// admin endpoint) — the guest POSTs one JSON row per subject
    /// via `host::http-post-json`.
    export sweep: func(model-url: string, subject-pattern: string,
                       target-sink-url: string, k-hops: u32,
                       opts: sweep-opts)
                       -> result<u32, string>;

    /// KNN over the cached embeddings. Sugar over `wf-vector:search`
    /// internally; kept as a first-class export so downstream queries
    /// can talk to one URL scheme (`wf-sagegraph:`) regardless of
    /// which tier answered.
    ///
    /// `index-url` names the wf-vector sink where the sweep wrote
    /// embeddings — the guest POSTs a `{"query": [...], "k": N}` body
    /// to that endpoint and parses the returned hit list.
    export search: func(index-url: string, query-vec: list<f32>,
                        k: u32, opts: search-opts)
                        -> result<list<hit>, string>;
}
