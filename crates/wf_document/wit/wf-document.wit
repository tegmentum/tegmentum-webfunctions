// wf_document WIT world — v1.1.0.
//
// One guest, two backends: Manticore for search, SirixDB (via
// sirix-sql-server) for durable, versioned document storage. Design
// memo: docs/design/wf-document.md in the wf-conformance repo.
//
// v1.1 adds **write-through** (`insert-doc`, `update-doc`,
// `delete-doc`) Writes go into Sirix (source of truth); Manticore
// catches up on the periodic sweep.
//
// Notes:
//
// 1. `search-url` and `sirix-url` are positional guest args. The
//    substrate side folds them through `wf:partial(<wasm>, ...)`.
//
// 2. Network I/O is a host import, not client-side ureq. The single
//    `host::http-post-json` shape matches wf_fulltext's.
//
// 3. Doc-ids are `sirix://<db>/<resource>/<node-key>` URIs (memo §06).
//
// 4. Deviation from memo §04: this world also exports `insert-batch` and
//    `delete-batch` (Manticore admin ops) alongside `search`, `fetch`,
//    and `list-revisions`.

package wf:document@1.1.0;

interface types {
    record doc-ref {
        id: string,
        revision: option<u64>,
    }

    record search-opts {
        limit: option<u32>,
        offset: option<u32>,
        fields: list<string>,
        highlight: bool,
        lang: option<string>,
        filter: option<string>,
        include-body: bool,
        body-content-type: option<string>,
        at-time: option<string>,
        at-rev: option<u64>,
    }

    record hit {
        doc: doc-ref,
        score: f64,
        snippet: option<string>,
        lang: option<string>,
        body: option<list<u8>>,
        content-type: option<string>,
        fields: list<tuple<string, string>>,
    }

    record document {
        doc: doc-ref,
        body: list<u8>,
        content-type: string,
    }

    record doc-write {
        id: string,
        fields: list<tuple<string, string>>,
        lang: option<string>,
    }

    /// Result of a Sirix-side write-through (v1.1). Sirix is source of
    /// truth for identity/revision. Manticore catches up on sweep.
    record write-result {
        doc: doc-ref,
        valid-from: string,
    }
}

interface host {
    http-post-json: func(url: string, body: string) -> result<string, string>;
}

world document {
    use types.{doc-ref, search-opts, hit, document, doc-write, write-result};

    import host;

    export search: func(
        search-url: string,
        sirix-url: string,
        index: string,
        query: string,
        opts: search-opts,
    ) -> result<list<hit>, string>;

    export fetch: func(
        sirix-url: string,
        doc: doc-ref,
    ) -> result<document, string>;

    export list-revisions: func(
        sirix-url: string,
        doc: doc-ref,
    ) -> result<list<u64>, string>;

    export insert-batch: func(
        search-url: string,
        index: string,
        docs: list<doc-write>,
    ) -> result<u32, string>;

    export delete-batch: func(
        search-url: string,
        index: string,
        ids: list<string>,
    ) -> result<u32, string>;

    /// Insert a new document into Sirix at database.resource.
    /// Sync: Sirix commits first (durable); Manticore catches up on sweep.
    /// Depends on sirix-sql-server DML support (currently SELECT-only).
    export insert-doc: func(
        sirix-url: string,
        database: string,
        resource-name: string,
        doc: list<u8>,
        content-type: string,
    ) -> result<write-result, string>;

    /// Update an existing document in Sirix, addressed by doc-ref.
    /// doc.revision (when set) is emitted as an OCC predicate.
    export update-doc: func(
        sirix-url: string,
        doc: doc-ref,
        body: list<u8>,
    ) -> result<write-result, string>;

    /// Delete a document from Sirix.
    export delete-doc: func(
        sirix-url: string,
        doc: doc-ref,
    ) -> result<_, string>;
}
