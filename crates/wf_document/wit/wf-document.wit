// wf_document WIT world â€” v1.2.0 (additive over v1.1 write-through).
//
// One guest, two backends: Manticore for search, SirixDB (via
// sirix-sql-server) for durable, versioned document storage. Design
// memo: docs/design/wf-document.md in the wf-conformance repo.
//
// v1.1 (already shipped, commit 3e5d833) adds write-through:
// `insert-doc`, `update-doc`, `delete-doc`. Writes go into Sirix
// (source of truth); Manticore catches up on the periodic sweep.
//
// v1.2 (this bump) adds four search-side capabilities from the memos'
// deferred list (`wf-document.md` Â§12, `wf-document-v1.md` Â§08).
// All four are additive on top of v1.1 â€” every earlier call is
// byte-for-byte unchanged when the new fields are None.
//   * Cross-index queries â€” `search-opts.indexes` unions multiple
//     registered indexes into a single Manticore request. `index`
//     positional stays the DEFAULT when this is None or empty.
//   * Faceting â€” new `facet` export aggregates hits by metadata
//     field via Manticore's `aggs` clause.
//   * MoreLikeThis â€” new `more-like-this` export. Manticore has no
//     native MLT; the guest fetches the seed doc from Sirix, extracts
//     top TF terms, and issues an OR query excluding the seed doc's
//     own `_id`.
//   * Vector search â€” new `vector-search` export. Vector is passed
//     verbatim to Manticore's k-NN. The target index MUST have a
//     `vector` field declared (operator's responsibility â€” this
//     substrate does not generate embeddings).
//
// Notes:
//
// 1. `search-url` and `sirix-url` are positional guest args. The
//    substrate side folds them through `wf:partial(<wasm>, ...)`.
//
// 2. Network I/O is a host import, not client-side ureq. The single
//    `host::http-post-json` shape matches wf_fulltext's. No new host
//    imports in v1.2 â€” every new capability dispatches through the
//    same primitive.
//
// 3. Doc-ids are `sirix://<db>/<resource>/<node-key>` URIs (memo Â§06).
//
// 4. Deviation from memo Â§04: this world also exports `insert-batch` and
//    `delete-batch` (Manticore admin ops) alongside `search`, `fetch`,
//    and `list-revisions`.

package wf:document@1.2.0;

interface types {
    record doc-ref {
        id: string,
        revision: option<u64>,
    }

    /// Search options. `include-body`, when true, triggers the guest to
    /// fetch each hit's document body from Sirix inline.
    ///
    /// v1.0 adds `at-time` and `at-rev` â€” the time-travel search
    /// selectors. Mutually exclusive; the guest returns Err when both
    /// are set. Both unset = current-only results (v0.2 semantics
    /// preserved).
    ///
    /// v1.2 adds `indexes` â€” cross-index query selector. When Some and
    /// non-empty, the guest builds one Manticore request over the union
    /// of the listed indexes. The `index` positional argument is the
    /// DEFAULT â€” used when `indexes` is None or an empty list.
    record search-opts {
        limit: option<u32>,
        offset: option<u32>,
        fields: list<string>,
        highlight: bool,
        lang: option<string>,
        filter: option<string>,
        include-body: bool,
        body-content-type: option<string>,
        at-time: option<string>,
        at-rev: option<u64>,
        /// v1.2 cross-index selector. When Some(non-empty), the guest
        /// unions the listed indexes into one Manticore request
        /// (comma-separated `table` field per Manticore's HTTP JSON API).
        /// The `index` positional argument is the DEFAULT when this is
        /// None or empty.
        indexes: option<list<string>>,
    }

    record hit {
        doc: doc-ref,
        score: f64,
        snippet: option<string>,
        lang: option<string>,
        body: option<list<u8>>,
        content-type: option<string>,
        fields: list<tuple<string, string>>,
    }

    record document {
        doc: doc-ref,
        body: list<u8>,
        content-type: string,
    }

    record doc-write {
        id: string,
        fields: list<tuple<string, string>>,
        lang: option<string>,
    }

    /// Result of a Sirix-side write-through (v1.1). Sirix is source of
    /// truth for identity/revision. Manticore catches up on sweep.
    record write-result {
        doc: doc-ref,
        valid-from: string,
    }

    /// v1.2 faceting bucket. `value` is stringified so the WIT type
    /// stays uniform across string / numeric bucket keys.
    record facet-value {
        value: string,
        count: u64,
    }

    /// v1.2 faceting result â€” one aggregation over one field. `values`
    /// is ordered by descending `count` (Manticore's default).
    record facet-result {
        field: string,
        values: list<facet-value>,
    }
}

interface host {
    http-post-json: func(url: string, body: string) -> result<string, string>;
}

world document {
    use types.{
        doc-ref, search-opts, hit, document, doc-write, write-result,
        facet-value, facet-result,
    };

    import host;

    /// Search Manticore at `search-url` for `query` in `index`. When
    /// `opts.include-body` is true, fetch each hit's body from Sirix at
    /// `sirix-url` and populate `hit.body` / `hit.content-type`.
    ///
    /// v1.2: when `opts.indexes` is Some(non-empty), the guest issues
    /// one cross-index request over the listed set and `index` is
    /// ignored. Absent or empty = single-index shape (backwards compat).
    export search: func(
        search-url: string,
        sirix-url: string,
        index: string,
        query: string,
        opts: search-opts,
    ) -> result<list<hit>, string>;

    export fetch: func(
        sirix-url: string,
        doc: doc-ref,
    ) -> result<document, string>;

    export list-revisions: func(
        sirix-url: string,
        doc: doc-ref,
    ) -> result<list<u64>, string>;

    export insert-batch: func(
        search-url: string,
        index: string,
        docs: list<doc-write>,
    ) -> result<u32, string>;

    export delete-batch: func(
        search-url: string,
        index: string,
        ids: list<string>,
    ) -> result<u32, string>;

    /// v1.1 write-through â€” insert a new document into Sirix.
    /// Sync: Sirix commits first (durable); Manticore catches up on sweep.
    /// Depends on sirix-sql-server DML support (currently SELECT-only).
    export insert-doc: func(
        sirix-url: string,
        database: string,
        resource-name: string,
        doc: list<u8>,
        content-type: string,
    ) -> result<write-result, string>;

    /// v1.1 write-through â€” update an existing document in Sirix.
    /// `doc.revision` (when set) is emitted as an OCC predicate.
    export update-doc: func(
        sirix-url: string,
        doc: doc-ref,
        body: list<u8>,
    ) -> result<write-result, string>;

    /// v1.1 write-through â€” delete a document from Sirix.
    export delete-doc: func(
        sirix-url: string,
        doc: doc-ref,
    ) -> result<_, string>;

    /// v1.2 faceting. Runs `query` in `index` (or across `opts.indexes`
    /// if set) and returns aggregation buckets for every field in
    /// `fields`. Reuses the same Manticore search backend; adds `aggs`
    /// clauses to the request body.
    export facet: func(
        search-url: string,
        index: string,
        query: string,
        fields: list<string>,
        opts: search-opts,
    ) -> result<list<facet-result>, string>;

    /// v1.2 MoreLikeThis. Manticore has no native MLT â€” implemented as
    /// "seed doc -> extract terms -> search with those terms":
    ///   1. Fetch the seed doc's body from Sirix (given `doc`).
    ///   2. Tokenize on ASCII alphanumerics, filter to words > 3 chars,
    ///      take the top 10 by term frequency.
    ///   3. OR-match those terms against Manticore, excluding the seed
    ///      doc's own `_id`.
    export more-like-this: func(
        search-url: string,
        sirix-url: string,
        index: string,
        doc: doc-ref,
        limit: u32,
        opts: search-opts,
    ) -> result<list<hit>, string>;

    /// v1.2 vector search. Passes `vector` verbatim to Manticore's k-NN
    /// operator. The target index MUST have a `vector` field declared
    /// (operator's responsibility â€” this substrate does NOT generate
    /// embeddings). `k` is the requested nearest-neighbor count.
    export vector-search: func(
        search-url: string,
        index: string,
        vector: list<f32>,
        k: u32,
        opts: search-opts,
    ) -> result<list<hit>, string>;
}
