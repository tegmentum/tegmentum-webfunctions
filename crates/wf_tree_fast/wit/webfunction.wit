// Webfunction WIT world, v0.3.3.
//
// v0.3.3 adds `follow-predicate` — a direct triple-pattern lookup that
// bypasses SPARQL entirely for the common walk-one-predicate case. On the
// wf_tree_fast benchmark this brings the marginal per-callback cost down
// from ~25 µs (prepared query) to ~5 µs by cutting the initial-binding
// substitution, the parsed-algebra iteration setup, and the WIT marshalling
// of binding-set records.
//
// Additive; older guests keep linking.

package stardog:webfunction@0.3.3;

interface types {
    variant value {
        iri(string),
        literal(literal),
        bnode(string),
    }

    record literal {
        label: string,
        datatype: string,
        lang: option<string>,
    }

    record binding {
        name: string,
        value: value,
    }

    type binding-set = list<binding>;

    record binding-sets {
        vars: list<string>,
        rows: list<binding-set>,
    }

    enum accuracy {
        verified,
        injected,
        accurate,
        mostly-accurate,
        probably-accurate,
        possibly-off,
        probably-off,
        random,
    }

    record cardinality {
        value: f64,
        accuracy: accuracy,
    }
}

/// Host callbacks. Provided by the plugin; consumed by the wasm component.
///
/// Enables recursive-query patterns: the component invokes `execute-query`
/// with the parent's bindings pre-attached, receives a fresh binding-set,
/// and can recurse to build tree-shaped output. See `crates/wf_tree/` for
/// the reference implementation.
interface host {
    use types.{binding, binding-sets, value};

    /// Execute a read-only SPARQL query in the caller's current
    /// transaction. `bindings` are pre-applied as if the query text opened
    /// with a `VALUES` block over each name — this is exactly the SPARQL
    /// 1.1 initial-bindings feature that plugins already support.
    ///
    /// Query forms:
    ///   * SELECT/ASK/DESCRIBE → returns binding-sets with the query's vars.
    ///   * CONSTRUCT → returns binding-sets with vars ("s","p","o"), one row
    ///     per triple.
    ///
    /// `max-rows`, if provided, bounds the returned result set. The host
    /// also enforces its configured hard cap (`webfunctions.callback.max.rows`,
    /// default 100_000) and truncates or errors past that.
    ///
    /// Fuel and memory limits are shared with the calling component — the
    /// callback does not get a fresh budget.
    execute-query: func(
        sparql: string,
        bindings: list<binding>,
        max-rows: option<u32>,
    ) -> result<binding-sets, string>;

    /// Current callback-recursion depth. Zero on the outermost wasm call;
    /// incremented every time `execute-query` re-enters a wasm component.
    /// The host also caps hard (`webfunctions.callback.max.depth`, default
    /// 100); this accessor lets the component unwind cleanly before the cap.
    callback-depth: func() -> u32;

    /// Parse a SPARQL SELECT/ASK/CONSTRUCT/DESCRIBE once and return an
    /// opaque handle the guest can pass to `run-prepared`. The host caches
    /// whatever it can — parsed algebra, precompiled evaluation step, plan
    /// — under the handle, so per-call cost drops to just the initial-
    /// binding substitution and the actual scan/iteration.
    ///
    /// Handles are valid only for the lifetime of the outer wf:call that
    /// created them. When that call returns, all handles it minted are
    /// invalidated together — the guest doesn't need to release them
    /// explicitly. Attempts to use a stale handle return err.
    prepare-query: func(sparql: string) -> result<u32, string>;

    /// Run a previously-prepared query with fresh initial bindings. Same
    /// return contract as `execute-query`. `handle` must be one this
    /// wf:call frame minted via `prepare-query`.
    run-prepared: func(
        handle: u32,
        bindings: list<binding>,
        max-rows: option<u32>,
    ) -> result<binding-sets, string>;

    /// Native triple-pattern lookup: returns the set of `?o` matching
    /// `(subject, predicate, ?o)` in the outer query's current transaction.
    /// No SPARQL parse, no algebra, no binding-set marshalling — the host
    /// hands back a plain list of value variants.
    ///
    /// This is the fast path for tree/graph traversal patterns whose
    /// child-lookup is a single triple pattern. Guests can layer more
    /// structure on top (attributes, joined siblings, etc.) via
    /// `execute-query`; `follow-predicate` is for the tight inner loop.
    follow-predicate: func(
        subject: value,
        predicate: value,
    ) -> result<list<value>, string>;
}

world webfunction {
    use types.{value, binding-sets, cardinality};

    // Host imports (new in v0.3.0).
    import host;

    // Exports (unchanged from v0.2.0).
    export evaluate: func(args: list<value>) -> result<binding-sets, string>;
    export aggregate-step: func(args: list<value>, mult: u64) -> result<_, string>;
    export aggregate-finish: func() -> result<binding-sets, string>;
    export cardinality-estimate: func(input: cardinality, args: list<value>) -> result<cardinality, string>;
    export doc: func() -> binding-sets;
}
