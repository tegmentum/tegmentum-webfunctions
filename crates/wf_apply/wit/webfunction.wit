// Webfunction WIT world, v0.4.0.
//
// v0.4.0 adds `invoke-wasm` — a host import that lets a guest call
// another wasm component identified by URL. This is what unlocks
// pure-wasm higher-order combinators (wf_apply, wf_map) that don't
// need to be re-implemented in every engine's plugin. The host
// resolves the URL through the same fetch + module-cache pipeline
// wf:call already uses, so caching, digest verification, and
// callback-depth accounting all carry over.
//
// Additive; a v0.3.x guest that only imports execute-query still
// links against the v0.4 world unchanged.

package stardog:webfunction@0.4.0;

interface types {
    variant value {
        iri(string),
        literal(literal),
        bnode(string),
    }

    record literal {
        label: string,
        datatype: string,
        lang: option<string>,
    }

    record binding {
        name: string,
        value: value,
    }

    type binding-set = list<binding>;

    record binding-sets {
        vars: list<string>,
        rows: list<binding-set>,
    }

    enum accuracy {
        verified,
        injected,
        accurate,
        mostly-accurate,
        probably-accurate,
        possibly-off,
        probably-off,
        random,
    }

    record cardinality {
        value: f64,
        accuracy: accuracy,
    }
}

/// Host callbacks. Provided by the plugin; consumed by the wasm component.
interface host {
    use types.{binding, binding-sets, value};

    execute-query: func(
        sparql: string,
        bindings: list<binding>,
        max-rows: option<u32>,
    ) -> result<binding-sets, string>;

    callback-depth: func() -> u32;

    prepare-query: func(sparql: string) -> result<u32, string>;

    run-prepared: func(
        handle: u32,
        bindings: list<binding>,
        max-rows: option<u32>,
    ) -> result<binding-sets, string>;

    /// Invoke another wasm component identified by `url`, with the given
    /// positional `args`. The host handles URL resolution (fetch, cache,
    /// component instantiation) and passes the arguments through the same
    /// invocation pipeline that backs `wf:call` — the guest sees only
    /// invocation semantics, not URL-resolution details.
    ///
    /// The invoked wasm runs in a fresh store but inherits the caller's
    /// callback-depth counter, so a recursive `invoke-wasm` chain still
    /// hits the host's max-depth cap. `execute-query` inside the invoked
    /// wasm sees the same store the caller was querying.
    ///
    /// v0.4.0 (new). Guests targeting v0.3.x that only import
    /// execute-query keep linking against v0.4.0 unchanged.
    invoke-wasm: func(
        url: string,
        args: list<value>,
    ) -> result<binding-sets, string>;
}

world webfunction {
    use types.{value, binding-sets, cardinality};

    import host;

    export evaluate: func(args: list<value>) -> result<binding-sets, string>;
    export aggregate-step: func(args: list<value>, mult: u64) -> result<_, string>;
    export aggregate-finish: func() -> result<binding-sets, string>;
    export cardinality-estimate: func(input: cardinality, args: list<value>) -> result<cardinality, string>;
    export doc: func() -> binding-sets;
}
