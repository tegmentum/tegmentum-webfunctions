// Webfunction WIT world, v0.5.0.
//
// v0.5.0 adds the `sink-*` host imports — handle-based I/O against an
// out-of-graph backend (SQLite, DuckDB, Postgres, SirixDB). This is what
// unlocks polyglot demotion: portable guests can materialize a
// relational-shaped subgraph to a SQL sink, or a tree-shaped subgraph to
// SirixDB, without the plugin knowing anything about the shape.
//
// Handle-based (not URL-per-call) so URL parsing + connection setup
// happens once per shape. Query strings are opaque so each backend can
// speak its native dialect — SQL for the relational sinks, XQuery/Brackit
// for SirixDB — without the WIT surface having to pick a lingua franca.
//
// Additive; guests importing v0.4.0 or earlier link against v0.5.0
// unchanged. The `types` and `host` interfaces are supersets of v0.4.0.

package stardog:webfunction@0.5.0;

interface types {
    variant value {
        iri(string),
        literal(literal),
        bnode(string),
    }

    record literal {
        label: string,
        datatype: string,
        lang: option<string>,
    }

    record binding {
        name: string,
        value: value,
    }

    type binding-set = list<binding>;

    record binding-sets {
        vars: list<string>,
        rows: list<binding-set>,
    }

    enum accuracy {
        verified,
        injected,
        accurate,
        mostly-accurate,
        probably-accurate,
        possibly-off,
        probably-off,
        random,
    }

    record cardinality {
        value: f64,
        accuracy: accuracy,
    }
}

/// Host callbacks. Provided by the plugin; consumed by the wasm component.
interface host {
    use types.{binding, binding-sets, value};

    execute-query: func(
        sparql: string,
        bindings: list<binding>,
        max-rows: option<u32>,
    ) -> result<binding-sets, string>;

    callback-depth: func() -> u32;

    prepare-query: func(sparql: string) -> result<u32, string>;

    run-prepared: func(
        handle: u32,
        bindings: list<binding>,
        max-rows: option<u32>,
    ) -> result<binding-sets, string>;

    invoke-wasm: func(
        url: string,
        args: list<value>,
    ) -> result<binding-sets, string>;

    /// Open a sink connection at `url` and return an opaque handle.
    ///
    /// Supported URL schemes are host-dependent; the reference plugin
    /// implementations recognize `sqlite://`, `duckdb://`, `postgres://`,
    /// and `sirix://`. A `#fragment` on the URL names the target
    /// table/document — e.g. `sqlite:///data/mv.db#person` opens the
    /// SQLite file at `/data/mv.db` and scopes subsequent operations to
    /// table `person`. Guests treat the fragment as metadata for their
    /// own query construction; the host does not enforce it.
    ///
    /// Handles are valid only within the outer wf:call frame that opened
    /// them — the host closes them automatically when that frame returns,
    /// so guests are not required to call sink-close explicitly. Opening
    /// the same URL twice yields two distinct handles (two connections).
    ///
    /// Errors: unknown scheme, file/network reachability, auth failure.
    sink-open: func(url: string) -> result<u32, string>;

    /// Execute an opaque query against the sink identified by `handle`.
    ///
    /// The query language is whichever the sink speaks natively — SQL for
    /// SQLite/DuckDB/Postgres, Brackit/XQuery for SirixDB. `params` are
    /// substituted for the backend's placeholder syntax (`?` for SQL,
    /// `$1`... for Postgres, backend-specific for Sirix); the host handles
    /// the translation.
    ///
    /// Return shape:
    ///   * DDL / INSERT / UPDATE / DELETE: empty binding-sets (vars=[],
    ///     rows=[]). Row count is not returned — guests that need it run
    ///     `SELECT changes()` (SQLite) / `RETURNING` (Postgres/DuckDB) as
    ///     a follow-up.
    ///   * SELECT: one row per result, one binding per projected column.
    ///     `name` is the column name from the query; `value` is the WIT
    ///     variant carrying the cell's typed value (literal for numeric/
    ///     text, iri for URL-shaped columns).
    sink-execute: func(
        handle: u32,
        query: string,
        params: list<value>,
    ) -> result<binding-sets, string>;

    /// Close a sink connection early. Optional — the outer wf:call frame
    /// closes any handles the guest opened. Explicit close is useful when
    /// the guest wants to release a scarce resource (Postgres connection
    /// pool slot) before the frame returns.
    sink-close: func(handle: u32) -> result<_, string>;
}

world webfunction {
    use types.{value, binding-sets, cardinality};

    import host;

    export evaluate: func(args: list<value>) -> result<binding-sets, string>;
    export aggregate-step: func(args: list<value>, mult: u64) -> result<_, string>;
    export aggregate-finish: func() -> result<binding-sets, string>;
    export cardinality-estimate: func(input: cardinality, args: list<value>) -> result<cardinality, string>;
    export doc: func() -> binding-sets;
}
