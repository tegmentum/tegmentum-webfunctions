// wf_fulltext WIT world — v0.1.0.
//
// Full-text search dispatch guest. One WIT world, one Manticore adapter
// today, OpenSearch as a follow-up swap (§12 of the design memo).
//
// Design memo: docs/design/wf-fulltext.md in the wf-conformance repo.
//
// Two shape notes.
//
// 1. `backend-url` is a positional guest arg, not a compile-time constant.
//    The substrate side folds it with `wf:partial(<wasm>, "<backend-url>",
//    "<index>", "<query>", <limit>)` so the guest stays stateless and the
//    same .wasm can point at any Manticore or OpenSearch endpoint. Adjusted
//    from the memo's §04 signature to match the substrate's arg model.
//
// 2. Network I/O is a host import, not client-side ureq. Every other guest
//    that talks to something out-of-sandbox (wf_sql via `sink-execute`,
//    wf_fetch via the descriptor's sink) goes through the substrate; the
//    ureq-in-`wasm32-wasip1` path is fragile enough that the substrate
//    idiom is to import a network callback and let the host implement it.
//    `http-post-json` is that callback here.

package wf:fulltext@0.1.0;

interface types {
    record query-opts {
        limit: option<u32>,
        offset: option<u32>,
        fields: list<string>,
        highlight: bool,
        lang: option<string>,
        filter: option<string>,
    }

    record hit {
        doc: string,
        score: f64,
        snippet: option<string>,
        lang: option<string>,
        fields: list<tuple<string, string>>,
    }

    /// One document to insert/replace in the fulltext backend. `id` is the
    /// subject IRI in literal-index mode; the periodic sweep in
    /// `wf_canonicalize` builds one of these per subject-with-matches.
    /// `fields` carries a (predicate → literal-lex) pair for each covered
    /// predicate the subject has; `lang` is the language tag (if any) the
    /// literals shared. Any per-doc structure richer than that stays out of
    /// this record — Manticore's "flat document" model is the honest v0.1
    /// scope.
    record doc-write {
        id: string,
        fields: list<tuple<string, string>>,
        lang: option<string>,
    }
}

/// Host callbacks. Provided by the plugin; consumed by the wasm component.
interface host {
    /// POST a JSON `body` to `url` and return the response body as a string.
    ///
    /// Success = HTTP 2xx; the response body is returned verbatim so the
    /// guest can parse it with its own serde_json. Any non-2xx response,
    /// network error, or malformed URL surfaces as `Err(<message>)`. The
    /// host is expected to set `Content-Type: application/json` on the
    /// request; the guest does not need to negotiate headers.
    http-post-json: func(url: string, body: string) -> result<string, string>;
}

world fulltext {
    use types.{query-opts, hit, doc-write};

    import host;

    export search: func(
        backend-url: string,
        index: string,
        query: string,
        opts: query-opts,
    ) -> result<list<hit>, string>;

    /// Insert/replace `docs` in `index` on the fulltext backend at
    /// `backend-url`. Returns the number of documents the backend
    /// acknowledged. Used by `wf_canonicalize`'s periodic sweep (memo
    /// §07) to keep the literal-index in sync with the graph's
    /// registered predicates.
    ///
    /// Semantics: each `doc-write` becomes an upsert keyed on `id`. The
    /// backend's `replace` shape is used so re-emitting the same id is
    /// idempotent — the sweep can safely re-send a document whose fields
    /// didn't change.
    ///
    /// Errors: transport failure (unreachable backend), auth failure,
    /// backend-side validation failure (unknown index, schema mismatch).
    /// Callers surface the error and skip the entry — never crash the
    /// sweep.
    export insert-batch: func(
        backend-url: string,
        index: string,
        docs: list<doc-write>,
    ) -> result<u32, string>;

    /// Delete documents by id from `index`. Returns the number of ids
    /// the backend acknowledged as deleted. Silently skips ids that
    /// don't exist (the sweep may delete tombstones the backend never
    /// saw; that's a valid "no-op" per the honesty invariant).
    ///
    /// Errors: same shape as `insert-batch`.
    export delete-batch: func(
        backend-url: string,
        index: string,
        ids: list<string>,
    ) -> result<u32, string>;
}
